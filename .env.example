# Database - Configurar com sua URL do Supabase
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# OpenAI - Para processamento de transcrições
OPENAI_API_KEY="sk-..."

# Resend - Para envio de emails
RESEND_API_KEY="re_..."

# Wasender - Para WhatsApp
WASENDER_API_KEY="..."
WASENDER_INSTANCE_ID="..."

# Google Tag Manager - container que carrega GA4 e Meta Pixel
# Exemplo: GTM-XXXXXXX (placeholder até o container do OKR ser criado)
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
